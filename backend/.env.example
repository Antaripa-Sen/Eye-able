# ============================================================
# BACKEND ENVIRONMENT VARIABLES
# HOW TO USE:
#   1. Copy this file: cp .env.example .env
#   2. Fill in every value below
#   3. NEVER commit .env to GitHub (it's in .gitignore)
# ============================================================

# ----- PostgreSQL Database -----
# Format: postgresql://USERNAME:PASSWORD@HOST:PORT/DATABASE_NAME
# Local example: postgresql://postgres:mypassword@localhost:5433/eyeable
DATABASE_URL=postgresql://postgres:Antaripa%402007@localhost:5433/eyeable

# ----- JWT Secret -----
# Generate one by running in terminal:  node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=23f2327988ec41685a916a66b9d86264e8c723dfd88c6c09f74280cc61462088dcfe426d7253cf5c481683ca3209c87140eea6f22616c2216b409811760478fd
JWT_EXPIRES_IN=7d

# ----- Server -----
PORT=4000
NODE_ENV=development

# ----- Frontend URL (for CORS) -----
# Change to your deployed frontend URL in production
FRONTEND_URL=http://localhost:5173
